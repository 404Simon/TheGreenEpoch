% Fix incompatability of the cleveref and acronym package in older texlive versions by 
% adding braces to acronym references, see https://tex.stackexchange.com/a/735502
\makeatletter
\AtBeginDocument
 {
   \def\ltx@label#1{\cref@label{#1}}
   \def\label@in@display@noarg#1{\cref@old@label@in@display{#1}}
\def\label@in@mmeasure@noarg#1{%
    \begingroup%
      \measuring@false%
      \cref@old@label@in@display{#1}
    \endgroup}%  
 } %
\makeatother

