%% This package creates the groups in the nomenclature
% -----------------------------------------
\usepackage{etoolbox}

% -----------------------------------------
\NewDocumentCommand\nomencldef{mmmO{}}{
  \newcounter{COUNT_#1}
  \expandafter\DeclareMathOperator\csname #1\endcsname{#2\stepcounter{COUNT_#1}}
  \AtEndDocument{%
    \ifthenelse{\value{COUNT_#1}>0}{
        \nomenclature[#4]{\(#2\)}{#3}
    }{}
  }
}
\input{nomenclature}

